{
  "name": "mdxit",
  "version": "0.1.0",
  "description": "用语义组件提升 Markdown 的信息密度，不变成 HTML。",
  "type": "module",
  "bin": {
    "mdxit": "./dist/cli/index.js"
  },
  "files": [
    "dist/cli",
    "src",
    "index.html",
    "vite.config.ts",
    "references/showcase.md"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.cli.json && vite build",
    "serve": "vite preview --host 127.0.0.1",
    "preview": "node dist/cli/index.js preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@antv/f2": "^5.14.0",
    "@mantine/core": "^9.2.0",
    "@mantine/hooks": "^9.2.0",
    "@mdx-js/react": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^4.0.2",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
